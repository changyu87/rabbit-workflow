{
  "env": {
    "RWF_REFRESH_EVERY": "10"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 0 > .claude/.rwf-counter"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/rwf-refresh.sh"
          }
        ]
      }
    ]
  }
}
