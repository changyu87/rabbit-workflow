{
  "env": {
    "RABBIT_REFRESH_EVERY": "20"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(git merge *)",
      "Bash(git push * main)",
      "Bash(git push origin main)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/scope-guard.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/stop-dispatcher.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/session-start-dispatcher.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/user-prompt-submit-dispatcher.py"
          }
        ]
      }
    ]
  }
}