{
  "env": {
    "RWF_REFRESH_EVERY": "20"
  },
  "permissions": {
    "deny": [
      "Write(.claude/**)",
      "Edit(.claude/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 0 > .rwf-prompt-counter"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/rwf-refresh.sh"
          }
        ]
      }
    ]
  }
}
