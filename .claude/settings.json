{
  "permissions": {
    "allow": [
      "Bash(rm *)",
      "Bash(python3 *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Write"
    ],
    "deny": [
      "Bash(gh pr merge *)",
      "Bash(git merge *)",
      "Bash(git push * main)",
      "Bash(git push *origin main*)",
      "Bash(git pull * main)",
      "Bash(git pull *origin main*)",
      "Bash(git commit --amend*)"
    ]
  },
  "env": {
    "RABBIT_REFRESH_EVERY": "20"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 0 > .rabbit-prompt-counter"
          },
          {
            "type": "command",
            "command": ".claude/hooks/session-init.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/refresh.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scope-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/sync-check.sh"
          }
        ]
      }
    ]
  }
}
