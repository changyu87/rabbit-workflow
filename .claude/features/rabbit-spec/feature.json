{
  "name": "rabbit-spec",
  "version": "1.4.0",
  "owner": "rabbit-workflow team",
  "tdd_state": "impl",
  "status": "active",
  "summary": "Owner of the rabbit workflow's spec-lifecycle skills. Hosts rabbit-spec-create (drafts initial spec bodies via the read-only spec-creator subagent) and rabbit-spec-update (revises existing specs; absorbed from rabbit-feature/rabbit-feature-spec).",
  "surface": {
    "skills": [
      "skills/rabbit-spec-create/SKILL.md",
      "skills/rabbit-spec-update/SKILL.md"
    ],
    "agents": [
      "agents/spec-creator.md"
    ],
    "hooks": [],
    "commands": [],
    "scripts": [
      "scripts/dispatch-spec-create.py"
    ]
  },
  "deprecation_criterion": "when Claude Code exposes native spec-lifecycle skills that supersede this feature",
  "updated": "2026-06-01",
  "manifest": [
    {
      "api": "publish_skill",
      "args": {
        "source": "skills/rabbit-spec-create/SKILL.md"
      }
    },
    {
      "api": "publish_skill",
      "args": {
        "source": "skills/rabbit-spec-update/SKILL.md"
      }
    },
    {
      "api": "publish_agent",
      "args": {
        "source": "agents/spec-creator.md"
      }
    }
  ],
  "runtime": {},
  "configuration": [],
  "prompts": [
    {
      "id": "spec-create",
      "kind": "subagent",
      "inject": [
        ".claude/features/policy/philosophy.md",
        ".claude/features/policy/coding-rules.md"
      ],
      "slots": [
        "feature_name",
        "paths_globs",
        "paths_resolved"
      ]
    },
    {
      "id": "rabbit-spec-update",
      "kind": "skill",
      "inject": [
        ".claude/features/policy/philosophy.md",
        ".claude/features/policy/spec-rules.md"
      ],
      "slots": [
        "args"
      ]
    }
  ],
  "spec_no_change_reason": "Spec amended in pre-cycle commit (multi-feature spec batch, bumped 1.3.0 -> 1.4.0 with new Inv 5 dual-mode feature_root rule); this TDD cycle implements the spec change."
}
