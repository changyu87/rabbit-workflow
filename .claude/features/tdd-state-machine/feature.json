{
  "name": "tdd-state-machine",
  "version": "1.0.0",
  "owner": {
    "primary": "rabbit-workflow team",
    "contact": "https://github.com/changyu87/rabbit-workflow/issues"
  },
  "status": "active",
  "tdd_state": "test-green",
  "deprecation": {
    "criterion": "When the TDD step model is replaced by a different lifecycle model; or when state tracking moves out of feature.json into a dedicated event log.",
    "successor": null
  },
  "contract": {
    "reads": [
      ".claude/features/<name>/feature.json",
      ".claude/features/<name>/test/run.sh"
    ],
    "writes": [
      ".claude/features/<name>/feature.json (tdd_state and updated fields only)"
    ],
    "invokes": [
      "jq",
      "bash <feature-dir>/test/run.sh"
    ]
  },
  "created": "2026-05-08",
  "updated": "2026-05-08"
}
