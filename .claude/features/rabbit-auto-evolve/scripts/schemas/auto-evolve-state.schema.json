{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.1.0",
  "owner": "cyxu",
  "deprecation_criterion": "when Claude Code or rabbit gains a native always-on autonomous-agent mode that supersedes this skill",
  "title": "rabbit-auto-evolve loop state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "queue",
    "in_flight",
    "last_merged_sha",
    "last_tagged_version",
    "consecutive_failures",
    "stop_requested",
    "restart_needed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "queue": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["issue", "decision", "feature"],
        "properties": {
          "issue": {"type": "integer"},
          "decision": {"type": "string"},
          "feature": {"type": "string"}
        }
      }
    },
    "in_flight": {
      "type": "array",
      "items": {"type": "integer"}
    },
    "last_merged_sha": {
      "type": ["string", "null"]
    },
    "last_tagged_version": {
      "type": ["string", "null"]
    },
    "consecutive_failures": {
      "type": "integer",
      "minimum": 0
    },
    "stop_requested": {
      "type": "boolean"
    },
    "restart_needed": {
      "type": ["string", "null"]
    },
    "defer_counts": {
      "type": "object",
      "description": "Per-issue consecutive-defer counter (issue #423 Part B), keyed by issue-number string. Optional/additive (schema 1.1.0).",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
