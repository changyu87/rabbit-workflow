{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.4.0",
  "owner": "rabbit-workflow team",
  "deprecation_criterion": "when Claude Code or rabbit gains a native always-on autonomous-agent mode that supersedes this skill",
  "title": "rabbit-auto-evolve loop state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "queue",
    "last_merged_sha",
    "last_tagged_version",
    "consecutive_failures",
    "stop_requested",
    "restart_needed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.4.0"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "queue": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "issue",
          "decision",
          "feature"
        ],
        "properties": {
          "issue": {
            "type": "integer"
          },
          "decision": {
            "type": "string"
          },
          "feature": {
            "type": "string"
          }
        }
      }
    },
    "in_flight": {
      "type": "array",
      "description": "RETIRED as required (schema 1.4.0, Inv 54): subsumed by dispatch_journal. Still accepted as an optional field for backward compatibility.",
      "items": {
        "type": "integer"
      }
    },
    "last_merged_sha": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_tagged_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "consecutive_failures": {
      "type": "integer",
      "minimum": 0
    },
    "stop_requested": {
      "type": "boolean"
    },
    "restart_needed": {
      "type": [
        "string",
        "null"
      ]
    },
    "defer_counts": {
      "type": "object",
      "description": "Per-issue consecutive-defer counter (issue #423 Part B), keyed by issue-number string. Optional/additive (schema 1.1.0).",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "pending_post_merge": {
      "type": "array",
      "description": "Merged PR numbers owed post-merge processing (phases 7-9, issue #499). Optional/additive (schema 1.2.0); cleared by run-post-merge.py once phases 7-9 complete.",
      "items": {
        "type": "integer"
      }
    },
    "decomposition_parents": {
      "type": "object",
      "description": "Machine-readable decomposition parent->children linkage (issue #721). Keyed by parent issue-number string; value is the list of child sub-issue numbers filed for that parent at decomposition time. The loop's close-decomposed-parents phase enumerates a parent's children from this map (never a prose comment table) and closes the parent once every child is closed, then removes the parent key. Optional/additive (schema 1.3.0).",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "integer"
        }
      }
    },
    "dispatch_journal": {
      "type": "object",
      "description": "Per-tick dispatch journal (issue #838, Inv 54). Keyed by tick-id string; each value records every subagent dispatched that tick so a resumed tick skips completed/pr_open entries and re-dispatches only the unfinished. Optional/additive (schema 1.4.0); subsumes the retired in_flight field.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "started_at",
          "entries"
        ],
        "properties": {
          "started_at": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "issue",
                "feature",
                "shape",
                "status"
              ],
              "properties": {
                "issue": {
                  "type": "integer"
                },
                "feature": {
                  "type": "string"
                },
                "shape": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "dispatched",
                    "pr_open",
                    "completed",
                    "aborted"
                  ]
                },
                "branch": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "worktree": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "pr": {
                  "type": [
                    "integer",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
