{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bug Filing Schema",
  "description": "Validates bug filing JSON files for rabbit-workflow features.",
  "type": "object",
  "required": ["name", "title", "status", "severity", "description", "filed_by"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Unique bug identifier (e.g. RABBIT-CAGE-1)."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short descriptive title for the bug."
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "reopened", "in_progress", "in_triage"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "filed_by": {
      "type": "string",
      "minLength": 1,
      "description": "Actor who filed the bug."
    },
    "related_feature": {
      "type": ["string", "null"],
      "description": "Feature name this bug belongs to, or null."
    },
    "filed": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when the bug was filed."
    },
    "closed": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when the bug was closed, or null."
    },
    "closed_by": {
      "type": ["string", "null"],
      "description": "Actor who closed the bug, or null."
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Audit trail of status transitions."
    }
  }
}
