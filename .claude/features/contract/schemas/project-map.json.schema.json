{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "project-map.json.schema.json",
  "title": "Project Map Schema",
  "description": "Validates .rabbit/rabbit-project/project-map.json in user-project plugin installs: declares which user-code path globs each rabbit feature governs plus the feature's bookkeeping directory.",
  "schema_version": "1.0.0",
  "owner": "rabbit-workflow team",
  "deprecation_criterion": "when rabbit's per-project plugin model is superseded by a native Claude Code workflow contract mechanism",
  "type": "object",
  "required": ["schema_version", "features"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "required": ["paths", "feature_dir"],
          "additionalProperties": false,
          "properties": {
            "paths": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "feature_dir": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
