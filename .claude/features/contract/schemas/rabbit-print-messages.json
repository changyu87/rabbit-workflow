{
  "schema_version": "1.0.0",
  "owner": "rabbit-workflow team",
  "deprecation_criterion": "when the [rabbit] print convention is replaced by a structured logging facility",
  "brand": "[🐇 rabbit 🐇]",
  "bar": "━━━",
  "colors": {
    "green": {
      "ansi": "\u001b[32m",
      "reset": "\u001b[0m"
    },
    "red": {
      "ansi": "\u001b[31m",
      "reset": "\u001b[0m"
    }
  },
  "messages": {
    "welcome": {
      "icon": "✅",
      "color": "green",
      "text": "Welcome — governing policies loaded"
    },
    "policy-drift": {
      "icon": "⚠️",
      "color": "red",
      "text": "Policy drift detected — CLAUDE.md regenerated from source files"
    },
    "surface-drift": {
      "icon": "🔄",
      "color": "red",
      "text": "Surface drift detected — rebuilt: {files}"
    },
    "scope-guard-off": {
      "icon": "🔓",
      "color": "red",
      "text": "SCOPE GUARD OFF (session override active)"
    },
    "scope-guard-bypassed": {
      "icon": "🔓",
      "color": "red",
      "text": "SCOPE GUARD BYPASSED (one-time override consumed — guard re-armed)"
    },
    "human-approval-bypass": {
      "icon": "🔑",
      "color": "red",
      "text": "HUMAN APPROVAL BYPASS ACTIVE — Step 4 skipped for all rabbit-feature-touch dispatches"
    },
    "skills-updated": {
      "icon": "✨",
      "color": "green",
      "text": "Skills updated: {names} — will reload automatically on next invocation"
    },
    "policy-refreshed": {
      "icon": "🔄",
      "color": "green",
      "text": "Policy refreshed"
    },
    "tdd-transition": {
      "icon": "🔧",
      "color": "green",
      "text": "{from_state} -> {to_state}"
    },
    "tdd-forced": {
      "icon": "🔧",
      "color": "red",
      "text": "FORCED: {from_state} -> {to_state}"
    }
  }
