{
  "name": "rabbit-cage",
  "version": "3.0.0",
  "owner": "rabbit-workflow team",
  "tdd_state": "impl",
  "summary": "Owns the entire Claude Code surface and all user-facing capabilities: hooks, commands, skills for scaffolding, project management, and installation. Bug-filing and backlog management are now owned by rabbit-bug and rabbit-backlog respectively.",
  "surface": {
    "hooks": [
      ".claude/hooks/refresh.sh",
      ".claude/hooks/session-init.sh",
      ".claude/hooks/scope-guard.sh",
      ".claude/hooks/sync-check.sh"
    ],
    "commands": [
      ".claude/commands/rabbit-refresh.md",
      ".claude/commands/rabbit-set-threshold.md",
      ".claude/commands/rabbit-project.md"
    ],
    "skills": [],
    "scripts": [
      ".claude/features/rabbit-cage/scripts/new-feature.sh",
      ".claude/features/rabbit-cage/scripts/validate-all.sh",
      ".claude/features/rabbit-cage/scripts/rabbit-project.sh",
      ".claude/features/rabbit-cage/scripts/generate-claude-md.sh",
      ".claude/features/rabbit-cage/scripts/workspace-tree.sh",
      ".claude/features/rabbit-cage/scripts/generate-skills-dir.sh"
    ],
    "settings": [
      ".claude/settings.json"
    ]
  },
  "deprecation_criterion": "when Claude Code exposes a native feature-container mechanism that subsumes this role",
  "updated": "2026-05-12"
}
